{
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!assets/|favicon.ico|manifest.json).*)",
      "destination": "/index.html"
    }
  ]
}
